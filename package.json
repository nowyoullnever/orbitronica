{
  "name": "orbitonic-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Orbit-based experimental music live editor",
  "main": "dist-electron/electron.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "verify:wam-assets": "node scripts/verify-wam-assets.mjs",
    "build": "npm run verify:wam-assets && tsc -b --force && node scripts/verify-preload.mjs && vite build && electron-builder --dir",
    "smoke:packaged-wam": "npm run build && node scripts/verify-wam-assets.mjs dist && node scripts/packaged-wam-smoke.mjs",
    "test": "node --experimental-strip-types --test test/*.test.ts tests/*.test.ts",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "@webaudiomodules/sdk": "0.0.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "soundtouchjs": "^0.1.30"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.orbitronica.app",
    "productName": "Orbitronica",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "dir",
      "signAndEditExecutable": false
    }
  }
}
