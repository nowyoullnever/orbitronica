{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "rootDir": "src/main",
    "outDir": "dist-electron"
  },
  "include": ["src/main/electron.ts", "src/main/preload.cts", "src/main/projectAssets.ts", "src/main/projectPayload.ts", "src/main/preferences.ts", "src/main/projectPaths.ts", "src/main/appMenu.ts", "src/main/rendererLaunchQuery.ts"]
}
